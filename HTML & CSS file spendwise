<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SpendWise</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0f0f10;
      --surface: #1a1a1d;
      --border: #2a2a2e;
      --text: #f0ede8;
      --muted: #6b6870;
      --accent: #e8ff47;
      --accent-dim: rgba(232, 255, 71, 0.08);
      --red: #ff5c5c;
      --green: #4ade80;
      --radius: 12px;
    }

    body {
      font-family: 'Syne', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 24px 16px 80px;
    }

    /* ── Header ── */
    header {
      max-width: 520px;
      margin: 0 auto 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      font-size: 1.3rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .logo span {
      color: var(--accent);
    }

    .month-nav {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: 'DM Mono', monospace;
      font-size: 0.82rem;
      color: var(--muted);
    }

    .month-nav button {
      background: none;
      border: 1px solid var(--border);
      color: var(--muted);
      width: 28px;
      height: 28px;
      border-radius: 6px;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
      font-size: 0.9rem;
    }

    .month-nav button:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* ── Summary cards ── */
    .cards {
      max-width: 520px;
      margin: 0 auto 24px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
    }

    .card-label {
      font-size: 0.72rem;
      font-family: 'DM Mono', monospace;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 6px;
    }

    .card-value {
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: -0.03em;
    }

    .card-value.accent { color: var(--accent); }
    .card-value.danger { color: var(--red); }
    .card-value.good   { color: var(--green); }

    /* budget progress bar */
    .budget-bar {
      margin-top: 10px;
      height: 3px;
      background: var(--border);
      border-radius: 2px;
      overflow: hidden;
    }

    .budget-fill {
      height: 100%;
      border-radius: 2px;
      background: var(--accent);
      transition: width 0.4s ease;
    }

    .budget-fill.over { background: var(--red); }

    /* ── Add expense form ── */
    .form-wrap {
      max-width: 520px;
      margin: 0 auto 28px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .form-toggle {
      width: 100%;
      background: none;
      border: none;
      color: var(--text);
      font-family: 'Syne', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      padding: 16px 20px;
      text-align: left;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .form-toggle .plus {
      font-size: 1.3rem;
      color: var(--accent);
      transition: transform 0.2s;
    }

    .form-toggle.open .plus { transform: rotate(45deg); }

    .form-body {
      display: none;
      padding: 0 20px 20px;
      flex-direction: column;
      gap: 12px;
    }

    .form-body.visible { display: flex; }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .field label {
      font-size: 0.72rem;
      font-family: 'DM Mono', monospace;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .field input,
    .field select {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: 'DM Mono', monospace;
      font-size: 0.88rem;
      padding: 10px 12px;
      outline: none;
      transition: border-color 0.15s;
      width: 100%;
    }

    .field input:focus,
    .field select:focus { border-color: var(--accent); }

    .field select option { background: #1a1a1d; }

    .btn-add {
      background: var(--accent);
      color: #0f0f10;
      border: none;
      border-radius: 8px;
      font-family: 'Syne', sans-serif;
      font-size: 0.9rem;
      font-weight: 700;
      padding: 12px;
      cursor: pointer;
      transition: opacity 0.15s;
      margin-top: 4px;
    }

    .btn-add:hover { opacity: 0.88; }

    /* ── Budget setter ── */
    .budget-row {
      max-width: 520px;
      margin: 0 auto 28px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .budget-row label {
      font-size: 0.75rem;
      font-family: 'DM Mono', monospace;
      color: var(--muted);
      white-space: nowrap;
    }

    .budget-row input {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: 'DM Mono', monospace;
      font-size: 0.88rem;
      padding: 8px 12px;
      width: 130px;
      outline: none;
      transition: border-color 0.15s;
    }

    .budget-row input:focus { border-color: var(--accent); }

    .btn-save-budget {
      background: none;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--muted);
      font-family: 'Syne', sans-serif;
      font-size: 0.8rem;
      padding: 8px 14px;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
    }

    .btn-save-budget:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Expense list ── */
    .list-wrap {
      max-width: 520px;
      margin: 0 auto;
    }

    .list-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
    }

    .list-title {
      font-size: 0.75rem;
      font-family: 'DM Mono', monospace;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .filter-tabs {
      display: flex;
      gap: 6px;
    }

    .tab {
      background: none;
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      padding: 4px 10px;
      cursor: pointer;
      transition: all 0.15s;
    }

    .tab.active {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--accent-dim);
    }

    .expense-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .expense-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 14px;
      animation: slideIn 0.2s ease;
    }

    @keyframes slideIn {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .category-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .expense-info { flex: 1; min-width: 0; }

    .expense-title {
      font-size: 0.92rem;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .expense-meta {
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 2px;
    }

    .expense-amount {
      font-family: 'DM Mono', monospace;
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--red);
      white-space: nowrap;
    }

    .btn-delete {
      background: none;
      border: none;
      color: var(--border);
      font-size: 1rem;
      cursor: pointer;
      padding: 4px;
      line-height: 1;
      transition: color 0.15s;
      flex-shrink: 0;
    }

    .btn-delete:hover { color: var(--red); }

    .empty-state {
      text-align: center;
      padding: 48px 0;
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      font-size: 0.85rem;
    }

    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(60px);
      background: var(--accent);
      color: #0f0f10;
      font-family: 'DM Mono', monospace;
      font-size: 0.82rem;
      font-weight: 500;
      padding: 10px 20px;
      border-radius: 100px;
      transition: transform 0.3s ease;
      pointer-events: none;
      white-space: nowrap;
    }

    .toast.show { transform: translateX(-50%) translateY(0); }
  </style>
</head>
<body>

  <header>
    <div class="logo">Spend<span>Wise</span></div>
    <div class="month-nav">
      <button id="prev-month">&#8592;</button>
      <span id="month-label"></span>
      <button id="next-month">&#8594;</button>
    </div>
  </header>

  <div class="cards">
    <div class="card">
      <div class="card-label">Spent</div>
      <div class="card-value accent" id="stat-spent">₹0</div>
    </div>
    <div class="card">
      <div class="card-label">Remaining</div>
      <div class="card-value" id="stat-remaining">—</div>
      <div class="budget-bar"><div class="budget-fill" id="budget-fill" style="width:0%"></div></div>
    </div>
  </div>

  <div class="form-wrap">
    <button class="form-toggle" id="form-toggle">
      Add expense
      <span class="plus">+</span>
    </button>
    <div class="form-body" id="form-body">
      <div class="form-row">
        <div class="field">
          <label>What for?</label>
          <input type="text" id="f-title" placeholder="e.g. Maggi at 2am" maxlength="40" />
        </div>
        <div class="field">
          <label>Amount (₹)</label>
          <input type="number" id="f-amount" placeholder="0" min="1" />
        </div>
      </div>
      <div class="form-row">
        <div class="field">
          <label>Category</label>
          <select id="f-category">
            <option value="food">🍜 Food</option>
            <option value="transport">🚌 Transport</option>
            <option value="education">📚 Education</option>
            <option value="entertainment">🎮 Entertainment</option>
            <option value="health">💊 Health</option>
            <option value="shopping">🛍️ Shopping</option>
            <option value="other">📦 Other</option>
          </select>
        </div>
        <div class="field">
          <label>Date</label>
          <input type="date" id="f-date" />
        </div>
      </div>
      <button class="btn-add" id="btn-add">Add Expense</button>
    </div>
  </div>

  <div class="budget-row">
    <label>Monthly budget ₹</label>
    <input type="number" id="budget-input" placeholder="e.g. 5000" min="1" />
    <button class="btn-save-budget" id="btn-save-budget">Set</button>
  </div>

  <div class="list-wrap">
    <div class="list-header">
      <span class="list-title" id="list-count">0 expenses</span>
      <div class="filter-tabs" id="filter-tabs">
        <button class="tab active" data-cat="all">All</button>
        <button class="tab" data-cat="food">Food</button>
        <button class="tab" data-cat="transport">Travel</button>
        <button class="tab" data-cat="entertainment">Fun</button>
      </div>
    </div>
    <div class="expense-list" id="expense-list"></div>
  </div>

  <div class="toast" id="toast"></div>

  <script src="app.js"></script>
</body>
</html>
